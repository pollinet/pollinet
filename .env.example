# Solana RPC endpoint.
# Defaults to https://api.devnet.solana.com when unset.
# Use http://127.0.0.1:8899 for a local validator.
SOLANA_URL="https://api.devnet.solana.com"

# Optional: base58-encoded private key for a pre-funded wallet.
# When set, examples will restore this wallet instead of creating a new one.
# Leave empty to let examples create a fresh airdrop-funded wallet automatically.
WALLET_PRIVATE_KEY=""

# AES-256-GCM encryption key for nonce bundle storage (hex-encoded, 32 bytes).
POLLINET_ENCRYPTION_KEY=""
